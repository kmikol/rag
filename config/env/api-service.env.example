# Copy and override for api-service deployments.

RAG_API_KEY=replace-me
POSTGRES_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_chunks
EMBEDDING_SERVICE_URL=http://embedding-service:8000
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_GENERATION_MODEL=gemma3:4b
OLLAMA_GENERATION_TIMEOUT_SECONDS=120
CHAT_MIN_TOP_SCORE=0.5
CHAT_MIN_USABLE_CHUNKS=1
WATCH_ROOTS=/watch
DOCUMENT_STORE_PATH=/documents
